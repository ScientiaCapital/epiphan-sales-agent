# Epiphan Sales Agent - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# APPLICATION
# ============================================
APP_NAME=Epiphan Sales Agent
ENVIRONMENT=development  # development | staging | production
DEBUG=false
VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8001

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
# Required for all features
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret

# Direct PostgreSQL connection (for SQLAlchemy)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/epiphan_sales_agent
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# AI PROVIDERS
# ============================================
# Anthropic (Required for Claude-based agents)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Cerebras (Optional - fast inference for simple tasks)
CEREBRAS_API_KEY=csk-...
CEREBRAS_API_BASE=https://api.cerebras.ai/v1

# DeepSeek (Optional - cost-effective alternative)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (Optional - model routing)
OPENROUTER_API_KEY=sk-or-...

# ============================================
# APOLLO ENRICHMENT (PHONES ARE GOLD!)
# ============================================
# Required for lead enrichment
APOLLO_API_KEY=your-apollo-api-key

# CRITICAL: Webhook for async phone delivery
# Without this, you only get employer/HQ phone (not mobile/direct!)
# See docs/reference/APOLLO_ENRICHMENT.md for details
APOLLO_WEBHOOK_URL=https://api.yourdomain.com/api/webhooks/apollo/phone-reveal
APOLLO_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ============================================
# LEAD HARVESTER WEBHOOK
# ============================================
# Secret for validating incoming Harvester webhooks
# Generate with: openssl rand -hex 32
HARVESTER_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ============================================
# HUBSPOT CRM
# ============================================
# Optional - for CRM sync
HUBSPOT_ACCESS_TOKEN=pat-na1-...
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PORTAL_ID=

# ============================================
# CLARI COPILOT
# ============================================
# Optional - for call intelligence
CLARI_API_KEY=
CLARI_API_BASE=https://api.clari.com/v1
CLARI_WORKSPACE_ID=

# ============================================
# SECURITY
# ============================================
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-64
EPIPHAN_API_KEY=generate-a-separate-api-key-for-token-exchange
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
CRM_ENCRYPTION_KEY=base64-encoded-32-byte-key

# ============================================
# OBSERVABILITY (LangSmith)
# ============================================
# Enable tracing for LangGraph agents
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=epiphan-sales-agent

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================
# BUDGET & RATE LIMITS
# ============================================
DAILY_BUDGET_USD=50.0
MONTHLY_BUDGET_USD=1000.0
COST_WARNING_THRESHOLD=0.80    # 80% - log warnings
COST_DOWNGRADE_THRESHOLD=0.90  # 90% - use cheaper models
COST_BLOCK_THRESHOLD=1.00      # 100% - block requests
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ============================================
# CLAY.COM ENRICHMENT (Fallback - 75+ providers)
# ============================================
# Clay fills phone/email gaps when Apollo comes up empty.
# Webhook-based: push lead → Clay enriches → Clay POSTs back.
CLAY_TABLE_WEBHOOK_URL=              # From Clay UI (table webhook URL)
CLAY_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
CLAY_ENABLED=false                   # Feature flag (disabled by default)

# ============================================
# OTHER ENRICHMENT APIS (Optional)
# ============================================
HUNTER_API_KEY=
