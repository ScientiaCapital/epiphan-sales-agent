# Epiphan Sales Agent - Production Environment Variables (Railway)
# Set these via `railway variable set KEY=VALUE --service epiphan-api`
# Use --skip-deploys to batch-set without triggering builds

# ============================================
# APPLICATION
# ============================================
ENVIRONMENT=production
API_PORT=8001
PORT=8001                                    # Railway convention (maps to internal port)
UVICORN_WORKERS=1                            # Keep at 1 for WebSocket session compatibility
CORS_ORIGINS=["https://YOUR_RAILWAY_DOMAIN"]

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
# Use direct connection (port 5432) for DDL, not pooler (6543)
DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ============================================
# REDIS (Railway-provisioned)
# ============================================
# Get with: railway variable list --service redis
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ============================================
# AI PROVIDERS (Required)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# AI PROVIDERS (Optional fallbacks)
# CEREBRAS_API_KEY=csk-...
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ============================================
# SECURITY (Required)
# ============================================
JWT_SECRET_KEY=generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
CRM_ENCRYPTION_KEY=generate-with-python-fernet

# ============================================
# APOLLO ENRICHMENT (Required for phone enrichment)
# ============================================
APOLLO_API_KEY=your-apollo-api-key
APOLLO_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
# Set AFTER deploy (chicken-and-egg: need domain first)
APOLLO_WEBHOOK_URL=https://YOUR_RAILWAY_DOMAIN/api/webhooks/apollo/phone-reveal

# ============================================
# LEAD HARVESTER WEBHOOK
# ============================================
HARVESTER_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ============================================
# HUBSPOT CRM (Optional)
# ============================================
# HUBSPOT_ACCESS_TOKEN=pat-na1-...
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_PORTAL_ID=

# ============================================
# OBSERVABILITY (Optional)
# ============================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=epiphan-sales-agent

# ============================================
# CLAY.COM ENRICHMENT (Disabled by default)
# ============================================
CLAY_ENABLED=false
# CLAY_TABLE_WEBHOOK_URL=
# CLAY_WEBHOOK_SECRET=

# ============================================
# BUDGET & RATE LIMITS
# ============================================
# DAILY_BUDGET_USD=50.0
# MONTHLY_BUDGET_USD=1000.0
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute
