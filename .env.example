# ===========================================
# EPIPHAN SALES AGENT - ENVIRONMENT VARIABLES
# ===========================================
# Copy this to .env and fill in your values

# ---------------------------------------------
# AI PROVIDERS (Multi-Provider Cost Optimization)
# ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...              # Claude models (quality)
CEREBRAS_API_KEY=csk-...                  # Ultra-fast inference (speed)
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
DEEPSEEK_API_KEY=...                      # Cost-effective LLM
OPENROUTER_API_KEY=...                    # Router for DeepSeek
OLLAMA_API_KEY=ollama                     # Local models (free)

# ---------------------------------------------
# HUBSPOT CRM (Primary CRM)
# ---------------------------------------------
HUBSPOT_ACCESS_TOKEN=...                  # Private app access token
HUBSPOT_CLIENT_ID=...                     # OAuth client ID
HUBSPOT_CLIENT_SECRET=...                 # OAuth client secret
HUBSPOT_PORTAL_ID=...                     # Your HubSpot portal ID

# ---------------------------------------------
# CLARI COPILOT (Conversation Intelligence)
# ---------------------------------------------
# Request read-only API access from Clari admin
CLARI_API_KEY=...                         # Read-only API key
CLARI_API_BASE=https://api.clari.com/v1
CLARI_WORKSPACE_ID=...                    # Your Clari workspace

# ---------------------------------------------
# DATABASE & CACHE
# ---------------------------------------------
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5433/epiphan_sales_agent
REDIS_URL=redis://localhost:6379/0
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ---------------------------------------------
# SUPABASE (Auth & Data)
# ---------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_KEY=...
SUPABASE_JWT_SECRET=...

# ---------------------------------------------
# SECURITY & ENCRYPTION
# ---------------------------------------------
JWT_SECRET_KEY=...                        # Generate: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
CRM_ENCRYPTION_KEY=...                    # Fernet key for API credentials

# ---------------------------------------------
# ENRICHMENT APIs
# ---------------------------------------------
APOLLO_API_KEY=...                        # Contact enrichment
HUNTER_API_KEY=...                        # Email discovery
CLEARBIT_API_KEY=...                      # Company enrichment

# ---------------------------------------------
# MONITORING & OBSERVABILITY
# ---------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=...
LANGSMITH_PROJECT=epiphan-sales-agent
SENTRY_DSN=...
ENVIRONMENT=development
VERSION=0.1.0

# ---------------------------------------------
# BUDGET & RATE LIMITS
# ---------------------------------------------
DAILY_BUDGET_USD=50.0
MONTHLY_BUDGET_USD=1000.0
COST_WARNING_THRESHOLD=0.80
COST_DOWNGRADE_THRESHOLD=0.90
COST_BLOCK_THRESHOLD=1.00
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---------------------------------------------
# APPLICATION
# ---------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
